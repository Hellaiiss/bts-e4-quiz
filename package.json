{
  "name": "bts-e4-quiz",
  "version": "1.0.0",
  "description": "Jeu multijoueur local de revision pour l'epreuve E4 du BTS Electrotechnique",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "build:exe": "pkg . --targets node20-win-x64 --output dist/quiz-e4.exe"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "questions.js",
      "node_modules/qrcode/**/*",
      "node_modules/socket.io/client-dist/**/*"
    ],
    "scripts": [
      "questions.js"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0"
  }
}
